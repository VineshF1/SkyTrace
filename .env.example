# N2YO API Configuration
# Get your API key from https://www.n2yo.com/api/
N2YO_API_KEY=your_n2yo_api_key_here

# Celestrak Configuration (optional - for OMM/GP data)
# No API key required for public Celestrak endpoints
CELESTRAK_BASE_URL=https://celestrak.org

# Application Settings
APP_LOG_LEVEL=INFO
APP_RATE_LIMIT_REQUESTS_PER_HOUR=800
APP_RATE_LIMIT_BURST=10